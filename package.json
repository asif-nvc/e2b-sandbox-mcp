{
  "name": "e2b-sandbox-mcp",
  "version": "1.0.1",
  "description": "MCP server connecting Claude Code with E2B cloud sandboxes for working on any GitHub repo",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "e2b-sandbox-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "e2b",
    "sandbox",
    "claude",
    "claude-code",
    "model-context-protocol",
    "ai",
