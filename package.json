    "cloud-sandbox",
    "code-execution"
  ],
  "author": "asif-nvc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asif-nvc/e2b-sandbox-mcp.git"
  },
  "homepage": "https://github.com/asif-nvc/e2b-sandbox-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.0",
    "e2b": "^2.14.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
